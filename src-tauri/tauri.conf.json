{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AmbientCard",
  "version": "0.2.0",
  "identifier": "com.cihebi2.ambientcard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AmbientCard",
        "width": 220,
        "height": 130,
        "minWidth": 200,
        "minHeight": 120,
        "maxWidth": 260,
        "maxHeight": 160,
        "visible": true,
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "AmbientCard Settings",
        "url": "/settings.html",
        "width": 1120,
        "height": 760,
        "minWidth": 940,
        "minHeight": 680,
        "visible": false,
        "center": true,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
