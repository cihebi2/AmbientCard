{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeskVocab",
  "version": "0.1.0",
  "identifier": "com.ciheb.deskvocab",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DeskVocab Overlay",
        "width": 396,
        "height": 236,
        "minWidth": 396,
        "minHeight": 236,
        "visible": true,
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "DeskVocab - Ambient Settings",
        "url": "/settings.html",
        "width": 1120,
        "height": 760,
        "minWidth": 940,
        "minHeight": 680,
        "visible": false,
        "center": true,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
